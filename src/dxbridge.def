LIBRARY dxbridge
EXPORTS
    DXBridge_Init               @1
    DXBridge_Shutdown           @2
    DXBridge_GetVersion         @3
    DXBridge_SupportsFeature    @4
    DXBridge_GetLastError       @5
    DXBridge_GetLastHRESULT     @6
    DXBridge_SetLogCallback     @7
    DXBridge_EnumerateAdapters  @8
    DXBridge_CreateDevice       @9
    DXBridge_DestroyDevice      @10
    DXBridge_GetFeatureLevel    @11
    DXBridge_CreateSwapChain    @12
    DXBridge_DestroySwapChain   @13
    DXBridge_ResizeSwapChain    @14
    DXBridge_GetBackBuffer      @15
    DXBridge_CreateRenderTargetView @16
    DXBridge_DestroyRTV         @17
    DXBridge_CreateDepthStencilView @18
    DXBridge_DestroyDSV         @19
    DXBridge_CompileShader      @20
    DXBridge_DestroyShader      @21
    DXBridge_CreateInputLayout  @22
    DXBridge_DestroyInputLayout @23
    DXBridge_CreatePipelineState @24
    DXBridge_DestroyPipeline    @25
    DXBridge_CreateBuffer       @26
    DXBridge_UploadData         @27
    DXBridge_DestroyBuffer      @28
    DXBridge_BeginFrame         @29
    DXBridge_SetRenderTargets   @30
    DXBridge_ClearRenderTarget  @31
    DXBridge_ClearDepthStencil  @32
    DXBridge_SetViewport        @33
    DXBridge_SetPipeline        @34
    DXBridge_SetVertexBuffer    @35
    DXBridge_SetIndexBuffer     @36
    DXBridge_SetConstantBuffer  @37
    DXBridge_Draw               @38
    DXBridge_DrawIndexed        @39
    DXBridge_EndFrame           @40
    DXBridge_Present            @41
    DXBridge_GetNativeDevice    @42
    DXBridge_GetNativeContext   @43
    DXBridge_QueryCapability    @44
